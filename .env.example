# Copy to .env and fill in. exact-api loads this on startup via dotenvy
# (walks up from CWD), so you don't need to source it manually — just
# `cargo run -p exact-api` from the workspace root.

# Postgres connection string. With nix develop, the local pg is at:
#   postgresql://localhost:5432/exact
# (assuming you've run `initdb`, `pg_ctl start`, `createdb exact`).
DATABASE_URL=postgresql://localhost:5432/exact

# Origin the browser sees. In dev that's the vite server which proxies /api
# and /auth to BIND_ADDR. In prod it's https://exact.run.
BACKEND_PUBLIC_URL=http://localhost:5173

# GitHub OAuth app credentials.
# Register at https://github.com/settings/applications/new
#   Application name:  exact (dev)
#   Homepage URL:      http://localhost:5173
#   Callback URL:      http://localhost:5173/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# HMAC key for signed session cookies. Must be >=64 bytes.
# Generate with: openssl rand -base64 64
SESSION_SECRET=

# Optional: first user logging in with this GitHub handle becomes admin.
BOOTSTRAP_ADMIN_GITHUB_LOGIN=

# Where the api listens. In Railway, set 0.0.0.0:$PORT.
BIND_ADDR=127.0.0.1:3000
